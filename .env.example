# ─── Database ───
DATABASE_URL=postgresql://shortfactory:localdev@localhost:5432/shortfactory
DATABASE_URL_ASYNC=postgresql+asyncpg://shortfactory:localdev@localhost:5432/shortfactory

# ─── Redis ───
REDIS_URL=redis://localhost:6379/0

# ─── Auth ───
JWT_SECRET_KEY=change-me-generate-256-bit-random-key
ENCRYPTION_KEY=change-me-generate-with-fernet-generate-key

# ─── OAuth (Social Login) ───
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Stripe ───
STRIPE_SECRET_KEY=sk_test_change_me
STRIPE_PUBLISHABLE_KEY=pk_test_change_me
STRIPE_WEBHOOK_SECRET=whsec_change_me

# ─── Platform API Keys (shared for users without BYOK) ───
PLATFORM_ANTHROPIC_API_KEY=
PLATFORM_GEMINI_API_KEY=
PLATFORM_ELEVENLABS_API_KEY=

# ─── S3-Compatible Storage (Cloudflare R2) ───
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=shortfactory-media
S3_PUBLIC_URL=

# ─── YouTube OAuth (Platform App) ───
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# ─── Frontend ───
FRONTEND_URL=http://localhost:3000

# ─── Monitoring ───
SENTRY_DSN=

# ─── App ───
ENVIRONMENT=development
LOG_LEVEL=INFO
