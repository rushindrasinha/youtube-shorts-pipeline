# Database
DATABASE_URL=postgresql://shortfactory:localdev@localhost:5432/shortfactory
DATABASE_URL_ASYNC=postgresql+asyncpg://shortfactory:localdev@localhost:5432/shortfactory

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET_KEY=change-me-in-production
ENCRYPTION_KEY=change-me-in-production

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Platform API Keys (used when user has no BYOK)
PLATFORM_ANTHROPIC_API_KEY=
PLATFORM_GEMINI_API_KEY=
PLATFORM_ELEVENLABS_API_KEY=

# S3 / Object Storage
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=shortfactory-media
S3_PUBLIC_URL=

# Frontend
FRONTEND_URL=http://localhost:3000

# App
ENVIRONMENT=development
